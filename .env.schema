# @generateTypes(lang='ts', path='src/varlock-env.d.ts')
# @defaultSensitive=inferFromPrefix('PUBLIC_')
# @defaultRequired=false
# ---

# Database connection URL
# @sensitive
DATABASE_URL=

# PropelAuth API key
# @sensitive
PROPELAUTH_API_KEY=

# PropelAuth verifier key (RSA public key)
# @sensitive
PROPELAUTH_VERIFIER_KEY=

# PropelAuth URL (public, used by client)
PUBLIC_AUTH_URL=

# Fogbender secret for server-side widget auth
# @sensitive
FOGBENDER_SECRET=

# Fogbender widget ID (public, used by client)
PUBLIC_FOGBENDER_WIDGET_ID=

# OpenAI API key for AI features
# @sensitive
OPENAI_API_KEY=

# Stripe secret key
# @sensitive
STRIPE_SECRET_KEY=

# Stripe price ID
# @sensitive
STRIPE_PRICE_ID=

# PostHog analytics key (public, used by client)
PUBLIC_POSTHOG_KEY=

# Site URL used by Astro for canonical URLs
# @sensitive=false
SITE_URL=
