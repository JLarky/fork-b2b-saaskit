# @defaultSensitive=inferFromPrefix(PUBLIC_)
# ---

# Primary site URL used by Astro config and setup checks
# @public @type=url
SITE_URL=

# Database connection string
# @required @type=url
DATABASE_URL=

# PropelAuth server credentials
# @required
PROPELAUTH_API_KEY=

# PropelAuth verifier public key
# @required
PROPELAUTH_VERIFIER_KEY=

# Optional Fogbender backend secret
FOGBENDER_SECRET=

# Optional OpenAI API key
OPENAI_API_KEY=

# Optional Stripe billing config
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=

# Public auth URL used by the client and server
# @required @public @type=url
PUBLIC_AUTH_URL=

# Optional client-side Fogbender widget ID
# @public
PUBLIC_FOGBENDER_WIDGET_ID=

# Optional public PostHog API key
# @public
PUBLIC_POSTHOG_KEY=

# Optional OG image debug flag
# @public @type=boolean
DEBUG_OG=

# Deployment environment exposed by Vercel
# @public
VERCEL_ENV=
