{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": true,
  "trailingComma": "es5",
  "ignorePatterns": ["/.astro", "dist", ".vscode", ".vercel", "src/db/meta/"],
  "overrides": [
    {
      "files": ["package.json"],
      "options": {
        "printWidth": 320
      }
    },
    {
      "files": ["*.json", "*.md"],
      "options": {
        "useTabs": false,
        "singleQuote": false
      }
    }
  ]
}
